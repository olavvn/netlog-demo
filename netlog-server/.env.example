# FastAPI/JWT
SECRET_KEY=changeme-generate-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=180

# postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://netlog:netlog@db:5432/netlog

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# production | development (development enables POST /dev/seed)
ENVIRONMENT=production

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,https://netlog-client.vercel.app

# Port uvicorn binds to inside the container
PORT=8080
