# React build
FROM docker.io/library/node:22-alpine AS build
WORKDIR /app

COPY netlog-client/package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install --no-audit --no-fund; fi
COPY netlog-client/ ./

# Empty = same-origin/relative requests, proxied to the api container by
# nginx.conf (see the /auth|inspection|dashboard|map location block below).
# Only override this if the api is NOT reachable via this nginx's proxy.
ARG VITE_API_URL=""
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

# Nginx runtime
FROM docker.io/library/nginx:stable-alpine
COPY netlog-client/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist/ /usr/share/nginx/html/
