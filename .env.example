# Credentials for the `db` (postgres) service in compose.yaml.
# Keep these in sync with the DATABASE_URL values in netlog-server/.env and netlog_db_v1/.env
POSTGRES_USER=netlog
POSTGRES_PASSWORD=netlog
POSTGRES_DB=netlog

# Passed as a build arg to netlog-client so it's baked into the Vite build.
# Point it at wherever netlog-server is reachable from the browser (not the container network).
VITE_API_URL=http://localhost:8080
